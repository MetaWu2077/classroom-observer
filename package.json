{
  "name": "classroom-observer",
  "version": "1.0.0",
  "description": "课堂观察应用 - 教师通过摄像头观察学生情况",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "vite build",
    "dev:renderer": "vite",
    "python": "python src/python/server.py",
    "dev": "npm run build:renderer && concurrently \"npm run python\" \"wait-on http-get://127.0.0.1:28765/stats && cross-env EXTERNAL_PYTHON_SERVER=1 electron .\"",
    "build": "npm run build:renderer && electron-builder"
  },
  "build": {
    "appId": "com.classroom.observer",
    "productName": "ClassroomObserver",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "src/python",
        "to": "python"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}